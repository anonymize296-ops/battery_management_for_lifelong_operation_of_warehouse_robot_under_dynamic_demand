module charging_state
charging:[0..1] init 0;
[gather_reward] (charging=0) | (charging=1) -> (charging'=0);
[stay_charging] (charging=1) -> (charging'=1);
[go_charge] (charging=0) -> (charging'=1);
[dead] (charging=0) -> (charging'=0);
endmodule

module cluster_evolution

cl:[0..2] init 0;
[evaluate] (task_present=1) & (t=0) -> 0.17500000000000004:(cl'=0)+0.825:(cl'=1);
[evaluate] (task_present=1) & (t=1) -> 0.17500000000000004:(cl'=0)+0.825:(cl'=1);
[evaluate] (task_present=1) & (t=2) -> 0.15000000000000002:(cl'=0)+0.85:(cl'=1);
endmodule

rewards "rew"
[gather_reward] (cl=0):1;
[gather_reward] (cl=1):2;
[gather_reward] (task_present=1): 1;

endrewards

rewards "batterycost"
[gather_reward] (battery < 20):1;
[go_charge] (battery < 20):1;
[stay_charging] (battery < 20):1;
[gather_reward] (battery > 80):1;
[go_charge] (battery > 80):1;
[stay_charging] (battery > 80):1;

endrewards

