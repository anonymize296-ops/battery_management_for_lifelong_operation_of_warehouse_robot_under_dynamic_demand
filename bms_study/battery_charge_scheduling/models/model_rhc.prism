mdp

module time_model
t:[0..3] init 0;
task_present:[0..1] init 0;
o:[0..1] init 0;
e:[0..1] init 0;
[observe] (t=0) & (o=0) & (e=0) -> 0.825:(task_present'=1) & (o'=1) + 0.175:(task_present'=0) & (o'=1);
[observe] (t=1) & (o=0) & (e=0) -> 0.825:(task_present'=1) & (o'=1) + 0.175:(task_present'=0) & (o'=1);
[observe] (t=2) & (o=0) & (e=0) -> 0.85:(task_present'=1) & (o'=1) + 0.15:(task_present'=0) & (o'=1);
[evaluate] (t<3) & (o=1) & (task_present=1) & (e=0) -> (e'=1);
[gather_reward] (t<3) & (o=1) & (task_present=1) & (e=1) -> (t'=t+1) & (o'=0) & (e'=0) ;
[go_charge] (t<3) & (o=1) & (task_present=1) & (e=1) -> (t'=t+1) & (o'=0) & (e'=0) ;
[stay_charging] (t<3) & (o=1) & (task_present=1) & (e=1) -> (t'=t+1) & (o'=0) & (e'=0) ;
[go_charge] (t<3) & (o=1) & (task_present=0) -> (t'=t+1) & (o'=0);
[stay_charging] (t<3) & (o=1) & (task_present=0) -> (t'=t+1) & (o'=0);
[dead] (t<3) -> (t'=t+1) & (o'=0);
endmodule

